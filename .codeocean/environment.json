{
	"version": 1,
	"base_image": "codeocean/jupyterlab:3.0.9-miniconda4.9.2-python3.8-ubuntu20.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"pip": {
			"packages": [
				{
					"name": "aind-data-schema",
					"version": "1.2.0"
				},
				{
					"name": "aind-data-schema-models",
					"version": "0.7.0"
				},
				{
					"name": "aws-requests-auth",
					"version": "0.4.3"
				},
				{
					"name": "boto3",
					"version": "1.35.81"
				},
				{
					"name": "kachery-cloud",
					"version": "0.4.10"
				},
				{
					"name": "matplotlib",
					"version": "3.7.5"
				},
				{
					"name": "numpy",
					"version": "1.24.4"
				},
				{
					"name": "pandas",
					"version": "2.0.3"
				},
				{
					"name": "pyyaml",
					"version": "6.0.3"
				},
				{
					"name": "watchtower",
					"version": "3.4.0"
				}
			],
			"options": {},
			"pre_install_options": {}
		},
		"vscode": {
			"packages": [
				{
					"name": "continue.continue"
				},
				{
					"name": "ms-python.python"
				},
				{
					"name": "ms-toolsai.jupyter"
				},
				{
					"name": "reageyao.biosyntax"
				},
				{
					"name": "reditorsupport.r"
				},
				{
					"name": "saoudrizwan.claude-dev"
				}
			],
			"version": "4.95.3"
		}
	},
	"env_variables": [
		{
			"name": "PROCESS_NAME",
			"value": "aind-fip-qc-raw"
		}
	]
}